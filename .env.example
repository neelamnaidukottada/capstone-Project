# =============================================================================
# Autonomous Campaign Manager — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Amzur LiteLLM Proxy (primary LLM provider) ---
AMZUR_API_KEY=sk-...
AMZUR_BASE_URL=https://litellm.amzur.com
LLM_MODEL=amzur-lite

# --- Supabase ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
SUPABASE_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# --- Next.js frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ENABLE_API_MOCKS=false

# --- Database (direct connection / LangGraph checkpointing) ---
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres
LANGGRAPH_CHECKPOINT_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# --- Redis (optional, for task queuing) ---
REDIS_URL=redis://localhost:6379/0
